# Copy to .env for local development. On Vercel, set these in Project → Settings → Environment Variables.
# Never commit .env.

# --- Sentry API (enrichment) ---
# Auth token for the carinya-sre-agent internal integration (read-only on the target project).
# Sentry → Settings → Developer Settings → Internal Integrations
SENTRY_TOKEN=

# Slugs from the Sentry project URL: sentry.io/organizations/{SENTRY_ORG_SLUG}/projects/{SENTRY_PROJECT_SLUG}/
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# --- Sentry webhook (ingress) ---
# Client secret from the same internal integration. Must match the secret configured on the
# integration webhook URL (POST /api/webhook). Used to verify Sentry-Hook-Signature (HMAC-SHA256).
SENTRY_WEBHOOK_SECRET=

# --- GitHub App (issue creation) ---
# Org-owned app installed on carinyaparc. See sre/README.md for setup.
# App ID from the app settings page. Private key: full PEM contents (use \n for newlines in Vercel).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Org and repo where triage issues are opened. Issue fields (e.g. Priority) are resolved from the org.
# Defaults to carinyaparc/website if unset.
GITHUB_REPO_OWNER=carinyaparc
GITHUB_REPO_NAME=website

# --- Claude (classification) ---
# Anthropic API key. Model defaults to claude-sonnet-4-6 in shared/claude.ts.
CLAUDE_API_KEY=
